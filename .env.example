# Como usar este arquivo:
# 1. Copie este arquivo para `.env` na raiz do projeto.
# 2. Se for usar Groq, mantenha LLM_PROVIDER=groq e preencha apenas GROQ_API_KEY.
# 3. Se for usar Ollama, altere LLM_PROVIDER=ollama e configure OLLAMA_BASE_URL/OLLAMA_MODEL.
# 4. Nunca versione o arquivo `.env` com chaves reais.

LLM_PROVIDER=groq

# Provider padrao/fallback operacional: Groq API
# Exemplo de .env usando Groq:
# LLM_PROVIDER=groq
# GROQ_API_KEY=sua_chave_real_da_groq
# GROQ_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Provider opcional para LLM quantizada servida via API compativel com Ollama
# Exemplo de .env usando Ollama:
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://servidor:11434
# OLLAMA_MODEL=llama3.1:8b-instruct-q4
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b-instruct-q4

LLM_MAX_TOKENS=300
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=30

RAG_TOP_K=3
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
AGENT_MAX_STEPS=3
CHAT_TIMEOUT_SECONDS=30
